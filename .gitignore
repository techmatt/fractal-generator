# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/


# Cygwin/Git-bash crash dumps (e.g. du.exe.stackdump)
*.stackdump

# Added by cargo

/target
# Isolated build dir used to compile/iterate while a long background run holds a
# file-lock on target/release/*.exe on Windows (see code_report.md / CLAUDE.md).
/target-*/
/target-test-build.log
/prompts

# Regenerable curated exports derived from the committed label corpus
# (data/label_corpus/.../images.jsonl) — not source, not committed.
/beautiful_locations.json

# Python palette-library prototype: harvested third-party .ugr/.map collections
# are local working inputs only — never redistribute (see palette_lib/REPORT.md).
# The colormap-derived palette library (clean/quarantined/log) IS committed; see
# the /data negations below.
/palette_cache/
__pycache__/
*.pyc

# Python uv environment (see CLAUDE.md "Python / uv"). The venv is regenerable
# from pyproject.toml + uv.lock via `uv sync` — both of those ARE committed.
/.venv/

# All generated artifacts live under the single out/ tree (see CLAUDE.md,
# "Generated-output convention"). Ignore the whole tree but keep its anchor so
# the directory survives a clean checkout. This blanket rule subsumes the old
# per-dir/per-file entries (/renders, /descend_strip_panels, *_stdout.txt, …).
/out/*
!/out/.gitkeep
# scratchpad/ is the canonical disposable temp dir (see CLAUDE.md disk-hygiene). It is
# gitignored and MUST never be on anyone's dependency path: nothing outside it imports it,
# and it is never the sole producer of a durable artifact. Load-bearing code -> tools/,
# findings text -> docs/findings/. (The 2026-07-15 promotion pass made this true; a file
# that broke — visual_dup/embed.py — is why this rule exists.)
/scratchpad/
# data/ is disposable by default, EXCEPT the committed colormap-derived palette
# library (reproducible from palette_lib/build_sheet.py — see CLAUDE.md
# "Persistent-store convention").
#
# NOTE (storage restructure): the regenerable file-count bombs — data/v{4,5,6,7}/
# aug_cache* and data/discovery/campaign2/{breadth,dive}/scratch — were physically
# RELOCATED out of the tree to ARTIFACTS_ROOT (default sibling
# ../fractal-generator-artifacts, env FRACTAL_ARTIFACTS_ROOT); readers/writers route
# through tools/corpus/artifacts.py. No .gitignore lines were dead: those families
# were only ever ignored by the blanket `/data/*` and `/data/discovery/**/scratch/`
# rules below, which remain load-bearing for OTHER in-tree paths and also serve as a
# backstop (any accidental in-tree rebuild stays un-committable). See
# docs/findings/storage_restructure.md.
/data/*
!/data/palettes/
/data/palettes/*
!/data/palettes/clean_colormaps.json
!/data/palettes/quarantined_colormaps.json
!/data/palettes/quarantine_log.json
# durable palette trajectory-feature file (tools/palettes/build_features.py):
# reproducible but load-bearing -- downstream samplers/dispatch load it directly.
!/data/palettes/score3_colormaps.json
!/data/palettes/palette_features.json
# durable merged palette pool (tools/palettes/build_pool.py): the preference
# network's palette source of truth (curated q2/q3 + quality-passing extracted).
!/data/palettes/pool_colormaps.json
# durable palette color-axis categorization (tools/palettes/build_categories.py):
# one hierarchical tree cut at k=8/12/16, nested; special cells + stored linkage.
!/data/palettes/palette_categories.json
# Hand-picked reference test fixtures (load-bearing metadata, not regenerable):
# the test render locations and the test palette selection.
!/data/test_renders.json
!/data/test_palettes.json
# Emission-v1 diversity target measure (tools/emission): a hand-editable config that is
# part of the deficit definition, not a regenerable artifact — commit it.
!/data/emission/
!/data/emission/target_measure.json
# Permanent label corpus (see data/label_corpus/CORPUS_SCHEMA.md): commit the
# tiny, irreplaceable metadata (schema, batch.json, images.jsonl, scores.json);
# gitignore crops/ — each crop is a pure function of its row's `render` block,
# rebuildable via present/render-one.
!/data/label_corpus/
/data/label_corpus/batches/*/crops/
# Wallpaper-quality corpus (tools/wallpaper/build_bootstrap.py) — same policy: commit
# batch.json + images.jsonl + scores.json, gitignore the rebuildable crops.
!/data/wallpaper_corpus/
/data/wallpaper_corpus/batches/*/crops/
# q4 window label store (tools/studies/q4_stage1_labelset.py; schema
# data/q4_window_corpus/README.md) — same policy: commit windows.jsonl + meta.json +
# README + scores.json, gitignore the crops (rebuildable: re-dump the field then
# colorize+crop via the capture stage).
!/data/q4_window_corpus/
/data/q4_window_corpus/batches/*/crops/
# disposable per-batch working data (previews, guided-descend pools, intermediate
# scores) — rebuildable from the committed metadata + generator, never committed.
/data/label_corpus/batches/*/_work/
# regenerable view (rev4_sanity_sheet.py) — not part of the commit policy.
/data/label_corpus/batches/*/sanity_contact_sheet.html

# Palette-preference query labels (tools/queries/launch_query_label_server.py):
# the authoritative per-batch hand-labeled tier store is tiny + irreplaceable, so
# commit it; the query batch (records/images) and stamped *_export_* dumps are
# regenerable and stay ignored.
!/data/queries/
/data/queries/*
!/data/queries/labels/
/data/queries/labels/*
!/data/queries/labels/coldstart_v2.json
!/data/queries/labels/warmstart_v1.json
!/data/queries/labels/prefv2_dramatic_v1.json
# sample_location.py eval pools: the runs were unseeded (GPU scoring is
# nondeterministic), so records.json (exact re-renderable configs of the validated
# top-18 pools) + summary.json are NON-regenerable — commit them. The .png sheets
# ARE regenerable (sample_location.py --rebuild-sheets), so they stay ignored.
!/data/queries/sampler_eval/
/data/queries/sampler_eval/*
!/data/queries/sampler_eval/summary.json
!/data/queries/sampler_eval/*/
/data/queries/sampler_eval/*/*
!/data/queries/sampler_eval/*/records.json

# Mandelbrot seed atlas (tools/atlas/build_atlas.py): the fitted theta_hat/conf
# artifact is a tiny (~12KB) load-bearing object the proposer reloads (atlas.py) --
# commit it like the calibration artifacts. Its round0 viz PNGs stay in out/.
!/data/atlas/

# Production discovery seeder ledgers (tools/atlas/production_seeder.py): the durable
# cross-run outcome/cell ledgers + per-outcome features + per-run summaries are
# load-bearing (the harvested-outcome store everything downstream consumes), committed
# like the atlas. Render scratch (contact_sheet.png review views) is disposable and
# lives under out/ (SHEETS_DIR) — never here; the rule below evicts any straggler.
!/data/discovery/
/data/discovery/**/contact_sheet.png
# The steered/dive frontier machinery (steered_frontier.py) adds disposable run
# output beside the durable ledgers: per-node render scratch (cheap JPGs, field
# dumps, expand/nodes logs, pool sheets) and regenerable run-internal state
# (novelty memory, node embeddings, frontier/dive state, harvest/prio/saturation
# logs) — crash-safety is by ledger-rebuild, so none of it is source. Only the
# durable harvested-outcome store (outcome_ledger/outcome_feats/probe_rejects/
# guard_telemetry/summary/walks/pool) is committed, matching the seeder above.
/data/discovery/**/scratch/
/data/discovery/**/*.log
/data/discovery/**/morph_mem.npz
/data/discovery/**/morph_admissions.npz
/data/discovery/**/dive_admissions.npz
/data/discovery/**/node_embs.npz
/data/discovery/**/state.json
/data/discovery/**/dive_state.json
/data/discovery/**/dive_log.jsonl
/data/discovery/**/harvest_log.jsonl
/data/discovery/**/prio_terms.jsonl
/data/discovery/**/saturation.jsonl
# Regenerable per-run overlays with no durable consumer: the deficit-scheduler decision
# trace, the within-run morph-embedding/dedup matrix, and the julia-hook seed-injection log
# (kin to node_embs/morph_mem above — rebuildable from the ledger + generator, never source).
/data/discovery/**/scheduler_trace.jsonl
/data/discovery/**/distinct_looks.npz
/data/discovery/**/julia_hooks.jsonl

# Phase-1 prospect location LIBRARY (tools/wallpaper/prospect_orchestrator.py). The
# durable records + the consolidated embeddings matrix are load-bearing and
# committed by EXACT PATH — not by directory. A bare `!/data/library_embeddings/`
# would re-include the per-cycle shards/*.npz stream, which is a regenerable overlay
# (consolidated into embeddings.npz) and MUST stay ignored. So: re-include the dir,
# re-exclude its contents, then negate only the one durable file.
!/data/library/
/data/library/*
!/data/library/library_records.jsonl
!/data/library_embeddings/
/data/library_embeddings/*
!/data/library_embeddings/embeddings.npz

# Large regeneratable datasets (see data_large/README.md)
/data_large/*
!/data_large/README.md
/dramatic_palettes/artist-fractals
/dramatic_palettes/viz_render/
/dramatic_palettes/densified/
/dramatic_palettes/viz/
/dramatic_palettes/viz_render_winners
